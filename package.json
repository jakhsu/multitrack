{
  "name": "multitrack",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "pnpm --filter @multitrack/example-react dev",
    "dev:react": "pnpm --filter @multitrack/example-react dev",
    "dev:vue": "pnpm --filter @multitrack/example-vue dev",
    "dev:svelte": "pnpm --filter @multitrack/example-svelte dev",
    "dev:vanilla": "pnpm --filter @multitrack/example-vanilla dev",
    "dev:all": "pnpm --filter './examples/*' --parallel dev",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.85",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "author": "Jack Hsu",
  "repository": {
    "type": "git",
    "url": "https://github.com/jakhsu/multitrack.git"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
